# Configuration Supabase pour marche241-api
# Copiez ce fichier vers .env et remplissez avec vos vraies valeurs

# URL de votre projet Supabase (trouvable dans Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Clé publique anon de Supabase (trouvable dans Settings > API)
SUPABASE_ANON_KEY=your-anon-key-here

# Clé de service Supabase (trouvable dans Settings > API) - GARDEZ SECRÈTE
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Configuration de la base de données (trouvable dans Settings > Database)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# Configuration JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# Configuration de l'application
APP_NAME="Marché 241 API"
APP_VERSION="1.0.0"
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=https://marche241.ga

# Configuration CORS
CORS_ORIGIN=http://localhost:3000

# Configuration de sécurité
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Configuration de stockage Supabase
SUPABASE_STORAGE_BUCKET=marche241-uploads

# Configuration email (si vous utilisez Supabase Auth)
SUPABASE_SMTP_HOST=smtp.supabase.co
SUPABASE_SMTP_PORT=587

# Variables d'environnement spécifiques à marche241
APP_NAME=Marche241 API
APP_VERSION=1.0.0
API_PREFIX=/api/v1

# Configuration de logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Configuration WhatsApp Business API
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token-here
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id-here
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token-here

# Configuration Resend pour l'envoi d'emails
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=noreply@resend.dev

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=mon-adresse@gmail.com
MAIL_PASSWORD=mon-mot-de-passe
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="mon-adresse@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"

WEBHOOK_VERIFICATION_URL=https://exemple.webhook.com
WEBHOOK_REGISTER_URL=https://exemple.webhook.com
WEBHOOK_PAYMENT=https://exemple.webhook.com

# Configuration Ebilling (Billing Easy)
EBILLING_API_ID=your-ebilling-api-id
EBILLING_API_SECRET=your-ebilling-api-secret
EBILLING_USER_NAME=your-ebilling-username
EBILLING_SHARED_KEY=your-ebilling-shared-key

# URLs Ebilling (Optionnel, valeurs de staging par défaut)
EBILLING_AUTH_URL=https://staging.billing-easy.net/shap/api/v1/merchant/auth
EBILLING_CREATE_INVOICE_URL=https://staging.billing-easy.net/shap/api/v1/merchant/create-invoice
EBILLING_SEND_USSD_PUSH_URL=https://staging.billing-easy.net/shap/api/v1/merchant/send-ussd-push
EBILLING_SERVER_URL=https://stg.billing-easy.com/api/v1/merchant/e_bills